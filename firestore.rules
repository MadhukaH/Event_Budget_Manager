rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Workspaces — authenticated users can read/write their own data
    // For now (development): allow all reads and writes
    // TODO: Replace with user-scoped rules when you add Firebase Auth
    match /workspaces/{workspaceId} {
      allow read, write: if true;

      // Expenses subcollection
      match /expenses/{expenseId} {
        allow read, write: if true;
      }
    }

    // App settings (e.g., Global Grant Fund)
    match /app_settings/{document} {
      allow read, write: if true;
    }
  }
}
